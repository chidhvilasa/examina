# EXAMINA Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to the repository.

# Authentication
EXAMINA_INVITE_CODE=change-this-to-a-32-char-hex-string
EXAMINA_ADMIN_TOKEN=change-this-to-a-32-char-hex-string

# Database
DATABASE_URL=sqlite:///./examina_dev.db

# PRISM Bridge
PRISM_BRIDGE_URL=http://localhost:9000
PRISM_BRIDGE_TOKEN=change-this-to-a-shared-secret

# ClamAV
CLAMAV_MODE=skip
CLAMAV_SOCKET=/var/run/clamav/clamd.ctl

# Application
EXAMINA_VERSION=0.0.0
LOG_LEVEL=WARNING
EXAMINA_ENV=development
