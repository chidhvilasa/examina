# EXAMINA Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to the repository.

# Authentication
EXAMINA_INVITE_CODE=change-this-to-a-32-char-hex-string
EXAMINA_ADMIN_TOKEN=change-this-to-a-32-char-hex-string

# Database
DATABASE_URL=sqlite:///./examina_dev.db

# PRISM Bridge — production (EXAMINA_ENV=production), RemoteBridgeClient over HTTP
PRISM_BRIDGE_URL=http://localhost:9000
PRISM_BRIDGE_TOKEN=change-this-to-a-shared-secret

# PRISM Bridge — development (EXAMINA_ENV unset/development), LocalBridgeClient
# via subprocess. PRISM_PYTHON must point at PRISM's own venv interpreter — a
# bare "python" almost never has PRISM's dependencies installed (see
# specs/TECH_DEBT.md TD-013).
PRISM_PATH=../PRISM
PRISM_PYTHON=../PRISM/.venv/Scripts/python.exe

# ClamAV
CLAMAV_MODE=skip
CLAMAV_SOCKET=/var/run/clamav/clamd.ctl

# CORS — comma-separated list of allowed browser origins.
# In production, set to the actual UI domain, e.g.:
#   EXAMINA_ALLOWED_ORIGINS=https://examina.yourdomain.com
EXAMINA_ALLOWED_ORIGINS=http://localhost:5173

# Application
EXAMINA_VERSION=0.0.0
LOG_LEVEL=WARNING
EXAMINA_ENV=development
